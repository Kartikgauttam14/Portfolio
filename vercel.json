{
  "projectSettings": {
    "name": "Portfolio",
    "buildCommand": "npm run build",
    "outputDirectory": ".next",
    "rootDirectory": ".",
    "framework": "nextjs"
  },
  "env": [
    {
      "key": "NEXT_PUBLIC_SITE_URL",
      "value": "https://kartikgauttam.com"
    }
  ],
  "regions": ["iad1"],
  "functions": {
    "api/**": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
